<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Landscot — Texas Land Development & Civil Engineering</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --white:#ffffff;
  --bg:#f8f9fa;
  --ink:#0f172a;
  --ink-mid:#334155;
  --muted:#64748b;
  --border:#e2e8f0;
  --accent:#2563eb; /* Professional Engineering Blue */
}
html{scroll-behavior:smooth}
body{background:var(--white);color:var(--ink);font-family:'Open Sans',sans-serif;font-size:15px;line-height:1.65;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{text-decoration:none;color:inherit}

header{background:var(--white);border-bottom:1px solid var(--border);padding:18px 48px;display:flex;align-items:center;justify-content:space-between;gap:20px;position:sticky;top:0;z-index:100}
.logo img{height:28px;width:auto;display:block}
.header-contact{display:flex;align-items:center;gap:24px;flex-wrap:wrap}
.header-phone{font-size:14px;font-weight:600;color:var(--ink);display:flex;align-items:center;gap:7px;transition:color 0.15s}
.header-phone:hover{color:var(--accent)}
.btn-dark{display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:var(--white);font-family:'Montserrat',sans-serif;font-size:13px;font-weight:700;letter-spacing:0.04em;padding:10px 22px;border-radius:4px;transition:background 0.15s;white-space:nowrap}
.btn-dark:hover{background:var(--accent)}

.hero{background:var(--bg);padding:100px 48px 90px;text-align:center;border-bottom:1px solid var(--border);background-image: radial-gradient(#e2e8f0 1px, transparent 1px);background-size: 30px 30px;}
.hero-inner{max-width:840px;margin:0 auto}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--white);border:1px solid var(--border);color:var(--muted);font-family:'Montserrat',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;padding:6px 16px;border-radius:100px;margin-bottom:28px}
.hero-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--accent);animation:pulse 2s ease infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.3;transform:scale(0.8)}}
.hero h1{font-family:'Montserrat',sans-serif;font-size:clamp(34px,5.5vw,54px);font-weight:800;line-height:1.1;letter-spacing:-0.02em;color:var(--ink);margin-bottom:24px}
.hero h1 span{color:var(--muted)}
.hero-sub{font-size:18px;color:var(--ink-mid);max-width:620px;margin:0 auto 40px;line-height:1.7}
.hero-sub strong{color:var(--ink);font-weight:700}
.hero-btns{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap}
.btn-outline{display:inline-flex;align-items:center;gap:8px;color:var(--ink);font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600;padding:10px 22px;border:1px solid var(--border);border-radius:4px;transition:border-color 0.15s;background:var(--white)}
.btn-outline:hover{border-color:var(--ink)}

.ticker-wrap{background:var(--ink);overflow:hidden;padding:14px 0}
.ticker-track{display:inline-flex;animation:ticker 35s linear infinite;white-space:nowrap}
.ticker-item{font-family:'Montserrat',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.8);padding:0 30px;display:inline-flex;align-items:center;gap:24px}
.ticker-item::after{content:'|';opacity:0.3}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

.bio-section{padding:90px 48px;border-bottom:1px solid var(--border);background:var(--white)}
.bio-inner{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:1.1fr 0.9fr;gap:72px;align-items:center}
@media(max-width:850px){.bio-inner{grid-template-columns:1fr;gap:50px}}
.section-eyebrow{font-family:'Montserrat',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:14px}
.section-heading{font-family:'Montserrat',sans-serif;font-size:clamp(28px,3.8vw,40px);font-weight:800;color:var(--ink);line-height:1.15;letter-spacing:-0.02em;margin-bottom:22px}
.bio-body{font-size:16px;color:var(--ink-mid);line-height:1.8}
.bio-body strong{color:var(--ink);font-weight:600}
.bio-checks{margin-top:30px;display:flex;flex-direction:column;gap:12px}
.bio-check{display:flex;align-items:center;gap:12px;font-size:14px;font-weight:500;color:var(--ink-mid)}
.check-icon{width:22px;height:22px;border-radius:50%;background:var(--bg);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--accent)}
.bio-stats{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.stat-card{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:28px 24px;text-align:center}
.stat-number{font-family:'Montserrat',sans-serif;font-size:38px;font-weight:800;color:var(--ink);line-height:1;margin-bottom:8px}
.stat-label{font-size:12px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em}

.services-section{padding:90px 48px;border-bottom:1px solid var(--border);background:var(--bg)}
.services-inner{max-width:1040px;margin:0 auto}
.services-header{text-align:center;margin-bottom:60px}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
@media(max-width:800px){.services-grid{grid-template-columns:1fr}}
.service-card{background:var(--white);padding:36px 30px;border:1px solid var(--border);border-radius:8px;display:flex;flex-direction:column;gap:12px;transition:transform 0.2s, box-shadow 0.2s}
.service-card:hover{transform:translateY(-4px);box-shadow:0 12px 24px rgba(0,0,0,0.05)}
.service-icon-wrap{width:44px;height:44px;margin-bottom:8px;color:var(--accent)}
.service-title{font-family:'Montserrat',sans-serif;font-size:15px;font-weight:700;color:var(--ink);line-height:1.3}
.service-desc{font-size:14px;color:var(--muted);line-height:1.6;flex:1}
.service-link{font-family:'Montserrat',sans-serif;font-size:12px;font-weight:700;color:var(--accent);letter-spacing:0.04em;display:inline-flex;align-items:center;gap:6px;margin-top:10px}

.cta-section{background:var(--ink);padding:100px 48px;text-align:center}
.cta-inner{max-width:700px;margin:0 auto}
.cta-eyebrow{font-family:'Montserrat',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:16px}
.cta-inner h2{font-family:'Montserrat',sans-serif;font-size:clamp(30px,4.5vw,48px);font-weight:800;color:var(--white);line-height:1.15;letter-spacing:-0.02em;margin-bottom:20px}
.cta-inner p{font-size:17px;color:rgba(255,255,255,0.6);max-width:520px;margin:0 auto 40px;line-height:1.7}
.btn-accent{display:inline-flex;align-items:center;gap:10px;background:var(--accent);color:var(--white);font-family:'Montserrat',sans-serif;font-size:15px;font-weight:700;padding:16px 36px;border-radius:4px;transition:filter 0.15s}
.btn-accent:hover{filter:brightness(1.1)}

footer{background:#0a0f1c;border-top:1px solid rgba(255,255,255,0.08);padding:30px 48px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
.footer-logo img{height:24px;width:auto;display:block}
.footer-right{font-size:12px;color:rgba(255,255,255,0.4)}

@media(max-width:600px){header{padding:16px 20px}.hero,.bio-section,.services-section,.cta-section{padding:70px 20px}}
</style>
</head>
